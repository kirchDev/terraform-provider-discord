{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "terraform-provider-discord",
  "version": "0.0.0",
  "private": false,
  "description": "OpenTofu / Terraform provider for Discord.",
  "keywords": [
    "discord",
    "guild",
    "iac",
    "infrastructure-as-code",
    "kirchdev",
    "opentofu",
    "terraform",
    "terraform-provider"
  ],
  "homepage": "https://github.com/kirchDev/terraform-provider-discord#readme",
  "bugs": {
    "url": "https://github.com/kirchDev/terraform-provider-discord/issues"
  },
  "license": "MIT",
  "author": "Titus Kirch <titus.kirch@kirch.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirchDev/terraform-provider-discord.git"
  },
  "type": "module",
  "scripts": {
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "check": "pnpm lint && pnpm format",
    "check:fix": "pnpm lint:fix && pnpm format:fix",
    "taze": "taze",
    "taze:w": "taze -w",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "taze": "^19.14.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2"
}
